        "@typescript-eslint/eslint-plugin": "^7.1.0",
        "@typescript-eslint/parser": "^7.1.0",
        "eslint": "^8.57.0",
        "lint-staged": "^15.2.2",
        "nodemon": "^3.0.3",
        "supertest": "^6.3.4",
        "ts-node": "^10.9.2",
        "tsoa": "^6.5.1",
